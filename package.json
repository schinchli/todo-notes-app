{
  "name": "instanote",
  "version": "0.1.0",
  "type": "module",
  "blocksTemplate": "default",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "aws-blocks"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test:unit && npm run build && npm run test:e2e",
    "test:unit": "tsx --test test/domain.test.ts",
    "spec": "blocks-generate-spec",
    "dev:server": "tsx watch aws-blocks/scripts/server.ts",
    "dev": "tsx watch aws-blocks/scripts/server.ts",
    "sandbox": "tsx aws-blocks/scripts/sandbox.ts",
    "sandbox:destroy": "tsx -C cdk aws-blocks/scripts/sandbox-destroy.ts",
    "sandbox:console": "tsx aws-blocks/scripts/console.ts",
    "cleanup": "tsx aws-blocks/scripts/cleanup.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "tsx aws-blocks/scripts/deploy.ts",
    "destroy": "tsx aws-blocks/scripts/destroy.ts",
    "test:e2e": "tsx --test-force-exit -C browser test/e2e.test.ts",
    "screenshots": "node scripts/screenshots.mjs",
    "vendorize": "blocks-vendorize",
    "check:fast": "npm run typecheck && npm run test:unit && npm run test:e2e",
    "ship": "npm run check:fast && npm run deploy"
  },
  "dependencies": {
    "@aws-blocks/blocks": "*",
    "@aws-sdk/client-polly": "^3.1085.0",
    "lit-html": "^3.2.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "aws-cdk": "^2.1129.0",
    "aws-cdk-lib": "^2.257.0",
    "aws-cdk-local": "^3.0.4",
    "constructs": "^10.6.0",
    "esbuild": "^0.27.1",
    "playwright": "^1.61.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.3"
  },
  "blocksTemplateVersion": "0.1.0"
}
